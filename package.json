{
  "name": "agent-permission-framework",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "agent-console": "cli/agent-console.cjs",
    "rcode": "cli/agent-console.cjs"
  },
  "description": "Rcode Desktop Application",
  "author": "Rcode",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:auth": "wrangler dev --config cloudflare/auth-worker/wrangler.jsonc --port 8788",
    "dev:server": "tsx watch server/index.ts",
    "dev:server:client": "cross-env PORT=8789 tsx watch server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "client": "cross-env VITE_API_BASE=http://localhost:8789 concurrently -k \"npm:dev:server:client\" \"npm:dev:web\" \"npm:client:electron\"",
    "client:electron": "wait-on http://localhost:5173 http://localhost:8789/api/health && cross-env ELECTRON_START_URL=http://localhost:5173 electron electron/main.cjs",
    "clean": "node scripts/clean.cjs",
    "build": "tsc && vite build",
    "build:server": "tsc -p tsconfig.server.json && node scripts/bundle-server.cjs",
    "build:app": "npm run build && npm run build:server && electron-builder --mac",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "typecheck:auth": "tsc -p cloudflare/auth-worker/tsconfig.json",
    "auth:types": "wrangler types --config cloudflare/auth-worker/wrangler.jsonc cloudflare/auth-worker/worker-configuration.d.ts",
    "auth:migrate:local": "wrangler d1 migrations apply rcode-auth --local --config cloudflare/auth-worker/wrangler.jsonc",
    "auth:migrate:remote": "wrangler d1 migrations apply rcode-auth --remote --config cloudflare/auth-worker/wrangler.jsonc",
    "auth:deploy:dry": "wrangler deploy --dry-run --config cloudflare/auth-worker/wrangler.jsonc",
    "auth:deploy": "wrangler deploy --config cloudflare/auth-worker/wrangler.jsonc",
    "test": "npm run build:server && node scripts/run-server-tests.cjs"
  },
  "build": {
    "appId": "com.agent-console.desktop",
    "productName": "Rcode",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "cli/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": null
    },
    "extraResources": [
      {
        "from": ".env.example",
        "to": ".env.example"
      },
      {
        "from": "dist-server-bundle",
        "to": "dist-server-bundle"
      },
      {
        "from": "config",
        "to": "config"
      }
    ]
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.1.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "smol-toml": "^1.7.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "wrangler": "^4.110.0"
  }
}
