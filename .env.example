# OpenAI-compatible chat completion endpoint.
# Works with providers that expose /v1/chat/completions.
AI_API_KEY=replace_me
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini

# NVIDIA NIM, used by config/providers.json.
NVIDIA_API_KEY=replace_me

# GitHub official remote MCP server. Use a fine-grained PAT with only the
# repository permissions Rcode should be allowed to use.
GITHUB_PERSONAL_ACCESS_TOKEN=

# Server
PORT=8787

# Cloudflare account service. Defaults to the deployed production Worker.
VITE_AUTH_API_URL=https://lxqandlzy.me
RCODE_AUTH_API_URL=https://lxqandlzy.me
