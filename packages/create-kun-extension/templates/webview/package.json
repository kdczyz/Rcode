{
  "name": "{{EXTENSION_ID}}",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test dist/test/state.test.js",
    "validate": "kun extension validate .",
    "pack": "npm run build && kun extension pack ."
  },
  "dependencies": {
    "@kun/extension-api": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  }
}
