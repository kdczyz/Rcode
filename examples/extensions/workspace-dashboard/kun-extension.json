{
  "$schema": "https://kun.dev/schemas/extensions/manifest/v1.json",
  "manifestVersion": 1,
  "apiVersion": "1.0.0",
  "name": "workspace-dashboard",
  "publisher": "kun-examples",
  "version": "0.1.0",
  "displayName": "Workspace Dashboard",
  "description": "A workspace-scoped dashboard built from public command, storage, and file APIs.",
  "license": "MIT",
  "engines": {
    "kun": ">=0.1.0"
  },
  "main": "dist/extension.js",
  "browser": "dist/webview/index.html",
  "activationEvents": [
    "onView:dashboard",
    "onCommand:refresh-dashboard"
  ],
  "contributes": {
    "commands": [
      {
        "id": "refresh-dashboard",
        "title": "Refresh Workspace Dashboard",
        "description": "Read the current workspace root and publish a bounded summary."
      }
    ],
    "views.editorTab": [
      {
        "id": "dashboard",
        "title": "Workspace Dashboard",
        "entry": "dist/webview/index.html",
        "localResourceRoots": ["dist/webview"]
      }
    ]
  },
  "permissions": [
    "commands.register",
    "ui.views",
    "webview",
    "storage.workspace",
    "workspace.read"
  ],
  "stateSchemaVersion": 1
}
