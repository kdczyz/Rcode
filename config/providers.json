{
  "activeProvider": "mimo",
  "providers": {
    "mimo": {
      "type": "openai-compatible",
      "displayName": "Xiaomi MiMo",
      "baseUrl": "https://api.xiaomimimo.com/v1",
      "apiKeyEnv": "AI_API_KEY",
      "chatCompletionsPath": "/chat/completions",
      "modelsPath": "/models",
      "defaultModel": "mimo-v2.5-pro",
      "fallbackModels": [
        "mimo-v2.5"
      ],
      "supports": {
        "chat": true,
        "tools": true,
        "streaming": true,
        "embeddings": false
      }
    }
  }
}
